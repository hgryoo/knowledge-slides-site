---
import Base from '../layouts/Base.astro';
import FeaturedDeck from '../components/FeaturedDeck.astro';
import DeckRow from '../components/DeckRow.astro';
import { loadDecks, groupByYear, groupByKind } from '../lib/decks';

const decks = loadDecks();
const published = decks.filter((d) => !d.draft);
const drafts = decks.filter((d) => d.draft);
const featured = published[0];
const rest = published.slice(1);
const yearGroups = groupByYear(rest);
const kindGroups = groupByKind(rest);
const total = published.length + drafts.length;

// Cross-link to knowledge-docs-site. Only rendered when the env var is
// set so local dev (which usually doesn't have docs-site running) stays
// clean; the CI workflow sets it to the deployed prod URL.
const docsSiteUrl = process.env.DOCS_SITE_URL ?? null;
---

<Base
  title="Hyunggyu Ryoo — Talks & Notes"
  description="주로 발표 자료. 곁가지로 코드 분석 노트와 읽은 책·논문 메모."
>
  <header class="masthead">
    <h1 class="masthead__name">Hyunggyu Ryoo</h1>
    <p class="masthead__role"><em>Talks &amp; Notes</em></p>
    <p class="masthead__lede">
      주로 발표 자료를 모아둡니다. 곁가지로 코드 분석 노트와
      읽은 책 · 논문에 대한 메모도 함께 둡니다.
      관심사는 데이터베이스 내부와 그 주변의 시스템 소프트웨어입니다.
    </p>
    {docsSiteUrl && (
      <p class="masthead__crosslink">
        함께 보기 · <a href={docsSiteUrl} target="_blank" rel="noopener">Notes &amp; Analyses ↗</a>
      </p>
    )}
  </header>

  {total === 0 ? (
    <p class="empty">
      등록된 자료가 없습니다. <code>knowledge-slides/decks/&lt;slug&gt;/metadata.json</code>을 추가하세요.
    </p>
  ) : (
    <>
      {featured && (
        <section class="block">
          <h2 class="block__heading">
            <span class="block__rule" aria-hidden="true"></span>
            <span class="block__label">Featured</span>
          </h2>
          <FeaturedDeck deck={featured} />
        </section>
      )}

      {(rest.length > 0 || drafts.length > 0) && (
        <section class="archive" data-view="year">
          <div class="archive__toggle" role="tablist" aria-label="Archive view">
            <button
              type="button"
              class="archive__toggle-btn is-active"
              data-view="year"
              role="tab"
              aria-selected="true"
            >By year</button>
            <button
              type="button"
              class="archive__toggle-btn"
              data-view="kind"
              role="tab"
              aria-selected="false"
            >By kind</button>
            {drafts.length > 0 && (
              <button
                type="button"
                class="archive__toggle-btn"
                data-view="draft"
                role="tab"
                aria-selected="false"
              >Drafts<span class="archive__toggle-count">{drafts.length}</span></button>
            )}
          </div>

          <div class="archive__pane archive__pane--year">
            {yearGroups.map((group) => (
              <section class="group">
                <h2 class="block__heading">
                  <span class="block__rule" aria-hidden="true"></span>
                  <span class="block__label">{group.year}</span>
                </h2>
                <div class="group__list">
                  {group.decks.map((deck) => (
                    <DeckRow deck={deck} />
                  ))}
                </div>
              </section>
            ))}
          </div>

          <div class="archive__pane archive__pane--kind">
            {kindGroups.length > 1 && (
              <div class="archive__chips" role="group" aria-label="Filter by kind">
                {kindGroups.map((group) => (
                  <button
                    type="button"
                    class="archive__chip is-active"
                    data-kind={group.kind}
                    aria-pressed="true"
                  >{group.label}</button>
                ))}
              </div>
            )}
            {kindGroups.map((group) => (
              <section class="group" data-kind={group.kind}>
                <h2 class="block__heading">
                  <span class="block__rule" aria-hidden="true"></span>
                  <span class="block__label">{group.label}</span>
                </h2>
                <div class="group__list">
                  {group.decks.map((deck) => (
                    <DeckRow deck={deck} showYear />
                  ))}
                </div>
              </section>
            ))}
          </div>

          {drafts.length > 0 && (
            <div class="archive__pane archive__pane--draft">
              <section class="group">
                <h2 class="block__heading">
                  <span class="block__rule" aria-hidden="true"></span>
                  <span class="block__label">In progress</span>
                </h2>
                <p class="archive__draft-note">
                  작성 중인 슬라이드. 빌드된 결과물이 있어도 메인 목록에는 노출되지 않습니다.
                </p>
                <div class="group__list">
                  {drafts.map((deck) => (
                    <DeckRow deck={deck} showYear />
                  ))}
                </div>
              </section>
            </div>
          )}
        </section>
      )}
    </>
  )}
</Base>

<style>
  .masthead {
    margin-bottom: 64px;
  }

  .masthead__name {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 60px;
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 0 0 6px;
    color: var(--ink);
  }

  .masthead__role {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--muted);
    margin: 0 0 28px;
    letter-spacing: -0.01em;
  }

  .masthead__role em {
    font-style: italic;
  }

  .masthead__lede {
    font-size: 17px;
    color: var(--ink-soft);
    max-width: 56ch;
    margin: 0;
  }

  .masthead__crosslink {
    margin: 18px 0 0;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 0.01em;
  }

  .masthead__crosslink a {
    color: var(--accent);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: var(--muted-soft);
    text-underline-offset: 3px;
  }

  .masthead__crosslink a:hover {
    text-decoration-color: var(--accent);
  }

  .empty {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 32px 0;
    text-align: center;
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 15px;
  }

  .empty code {
    background: rgba(168, 51, 42, 0.08);
    color: var(--accent);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 13px;
  }

  .block {
    margin-bottom: 48px;
  }

  .block__heading {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 12px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .block__rule {
    width: 22px;
    height: 1px;
    background: var(--muted);
  }

  .group {
    margin-bottom: 48px;
  }

  .archive__toggle {
    display: inline-flex;
    gap: 4px;
    padding: 3px;
    margin: 0 0 36px;
    border: 1px solid var(--rule);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.5);
  }

  .archive__toggle-btn {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 6px 14px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
    border-radius: 3px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .archive__toggle-btn:hover {
    color: var(--ink);
  }

  .archive__toggle-btn.is-active {
    background: var(--ink);
    color: var(--paper);
  }

  .archive__pane--kind,
  .archive__pane--draft { display: none; }

  .archive[data-view="kind"] .archive__pane--year,
  .archive[data-view="kind"] .archive__pane--draft { display: none; }
  .archive[data-view="kind"] .archive__pane--kind { display: block; }

  .archive[data-view="draft"] .archive__pane--year,
  .archive[data-view="draft"] .archive__pane--kind { display: none; }
  .archive[data-view="draft"] .archive__pane--draft { display: block; }

  .archive__toggle-count {
    display: inline-block;
    margin-left: 6px;
    padding: 0 5px;
    border-radius: 999px;
    background: var(--accent);
    color: var(--paper);
    font-size: 10px;
    font-weight: 600;
    line-height: 1.6;
    letter-spacing: 0;
  }

  .archive__toggle-btn.is-active .archive__toggle-count {
    background: var(--paper);
    color: var(--accent);
  }

  .archive__draft-note {
    margin: 0 0 18px;
    font-size: 13px;
    color: var(--muted);
    font-family: var(--font-sans);
  }

  .archive__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: -12px 0 28px;
  }

  .archive__chip {
    appearance: none;
    background: transparent;
    border: 1px solid var(--rule);
    padding: 4px 12px;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--muted);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }

  .archive__chip:hover {
    color: var(--ink);
    border-color: var(--muted-soft);
  }

  .archive__chip.is-active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--paper);
  }

  .archive__chip.is-active::before {
    content: "✓ ";
    margin-right: 2px;
  }

  .group.is-hidden { display: none; }

  @media (max-width: 640px) {
    .masthead__name {
      font-size: 44px;
    }
    .masthead__role {
      font-size: 19px;
    }
    .masthead {
      margin-bottom: 48px;
    }
  }
</style>

<script>
  const archive = document.querySelector<HTMLElement>('.archive');
  if (archive) {
    const buttons = archive.querySelectorAll<HTMLButtonElement>('.archive__toggle-btn');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const view = btn.dataset.view ?? 'year';
        archive.dataset.view = view;
        buttons.forEach((b) => {
          const active = b.dataset.view === view;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-selected', active ? 'true' : 'false');
        });
      });
    });

    // Per-kind chip toggles inside the By kind pane. Each chip mirrors
    // the visibility of its matching `.group[data-kind=...]` section.
    const kindPane = archive.querySelector<HTMLElement>('.archive__pane--kind');
    if (kindPane) {
      const chips = kindPane.querySelectorAll<HTMLButtonElement>('.archive__chip');
      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          const kind = chip.dataset.kind;
          if (!kind) return;
          const active = !chip.classList.contains('is-active');
          chip.classList.toggle('is-active', active);
          chip.setAttribute('aria-pressed', active ? 'true' : 'false');
          kindPane
            .querySelectorAll<HTMLElement>(`.group[data-kind="${kind}"]`)
            .forEach((g) => g.classList.toggle('is-hidden', !active));
        });
      });
    }
  }
</script>
