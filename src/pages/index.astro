---
import Base from '../layouts/Base.astro';
import FeaturedDeck from '../components/FeaturedDeck.astro';
import DeckRow from '../components/DeckRow.astro';
import { loadDecks, groupByKind } from '../lib/decks';

const decks = loadDecks();
const published = decks.filter((d) => !d.draft);
const drafts = decks.filter((d) => d.draft);
const featured = published[0];
const rest = published.slice(1);
const kindGroups = groupByKind(rest);
const total = published.length + drafts.length;

// Cross-link to knowledge-docs-site. Only rendered when the env var is
// set so local dev (which usually doesn't have docs-site running) stays
// clean; the CI workflow sets it to the deployed prod URL.
const docsSiteUrl = process.env.DOCS_SITE_URL ?? null;
---

<Base
  title="Hyunggyu Ryoo — Talks & Notes"
  description="주로 발표 자료. 곁가지로 코드 분석 노트와 읽은 책·논문 메모."
>
  <header class="masthead">
    <h1 class="masthead__name">Hyunggyu Ryoo</h1>
    <p class="masthead__role"><em>Talks &amp; Notes</em></p>
    <p class="masthead__lede">
      주로 발표 자료를 모아둡니다. 곁가지로 코드 분석 노트와
      읽은 책 · 논문에 대한 메모도 함께 둡니다.
      관심사는 데이터베이스 내부와 그 주변의 시스템 소프트웨어입니다.
    </p>
    {docsSiteUrl && (
      <p class="masthead__crosslink">
        함께 보기 · <a href={docsSiteUrl} target="_blank" rel="noopener">Notes &amp; Analyses ↗</a>
      </p>
    )}
  </header>

  {total === 0 ? (
    <p class="empty">
      등록된 자료가 없습니다. <code>knowledge-slides/decks/&lt;slug&gt;/metadata.json</code>을 추가하세요.
    </p>
  ) : (
    <>
      {featured && (
        <section class="block">
          <h2 class="block__heading">
            <span class="block__rule" aria-hidden="true"></span>
            <span class="block__label">Featured</span>
          </h2>
          <FeaturedDeck deck={featured} />
        </section>
      )}

      {(rest.length > 0 || drafts.length > 0) && (
        <section class="archive">
          {(kindGroups.length > 1 || drafts.length > 0) && (
            <div class="archive__chips" role="group" aria-label="Filter">
              {kindGroups.map((group) => (
                <button
                  type="button"
                  class="archive__chip is-active"
                  data-kind={group.kind}
                  aria-pressed="true"
                >{group.label}</button>
              ))}
              {drafts.length > 0 && (
                <>
                  <span class="archive__chip-sep" aria-hidden="true"></span>
                  <button
                    type="button"
                    class="archive__chip archive__chip--draft"
                    data-kind="draft"
                    aria-pressed="false"
                  >Drafts<span class="archive__chip-count">{drafts.length}</span></button>
                </>
              )}
            </div>
          )}

          {kindGroups.map((group) => (
            <section class="group" data-kind={group.kind}>
              <h2 class="block__heading">
                <span class="block__rule" aria-hidden="true"></span>
                <span class="block__label">{group.label}</span>
              </h2>
              <div class="group__list">
                {group.decks.map((deck) => (
                  <DeckRow deck={deck} showYear />
                ))}
              </div>
            </section>
          ))}

          {drafts.length > 0 && (
            <section class="group is-hidden" data-kind="draft">
              <h2 class="block__heading">
                <span class="block__rule" aria-hidden="true"></span>
                <span class="block__label">In progress</span>
              </h2>
              <p class="archive__draft-note">
                작성 중인 슬라이드. 빌드된 결과물이 있어도 메인 목록에는 노출되지 않습니다.
              </p>
              <div class="group__list">
                {drafts.map((deck) => (
                  <DeckRow deck={deck} showYear />
                ))}
              </div>
            </section>
          )}
        </section>
      )}
    </>
  )}
</Base>

<style>
  .masthead {
    margin-bottom: 64px;
  }

  .masthead__name {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 60px;
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 0 0 6px;
    color: var(--ink);
  }

  .masthead__role {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--muted);
    margin: 0 0 28px;
    letter-spacing: -0.01em;
  }

  .masthead__role em {
    font-style: italic;
  }

  .masthead__lede {
    font-size: 17px;
    color: var(--ink-soft);
    max-width: 56ch;
    margin: 0;
  }

  .masthead__crosslink {
    margin: 18px 0 0;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 0.01em;
  }

  .masthead__crosslink a {
    color: var(--accent);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: var(--muted-soft);
    text-underline-offset: 3px;
  }

  .masthead__crosslink a:hover {
    text-decoration-color: var(--accent);
  }

  .empty {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 32px 0;
    text-align: center;
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 15px;
  }

  .empty code {
    background: rgba(168, 51, 42, 0.08);
    color: var(--accent);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 13px;
  }

  .block {
    margin-bottom: 48px;
  }

  .block__heading {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 12px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .block__rule {
    width: 22px;
    height: 1px;
    background: var(--muted);
  }

  .group {
    margin-bottom: 48px;
  }

  .archive__chips {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin: 0 0 36px;
  }

  .archive__chip {
    appearance: none;
    background: transparent;
    border: 1px solid var(--rule);
    padding: 4px 12px;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--muted);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }

  .archive__chip:hover {
    color: var(--ink);
    border-color: var(--muted-soft);
  }

  .archive__chip.is-active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--paper);
  }

  .archive__chip.is-active::before {
    content: "✓ ";
    margin-right: 2px;
  }

  /* Drafts is a separate filter dimension from kind, so it sits past
   * a thin vertical rule and uses a dashed outline when inactive to
   * signal "not the same axis as the other chips". */
  .archive__chip-sep {
    display: inline-block;
    width: 1px;
    align-self: stretch;
    margin: 4px 6px;
    background: var(--rule);
  }

  .archive__chip--draft {
    border-style: dashed;
  }

  .archive__chip--draft.is-active {
    border-style: solid;
  }

  .archive__chip-count {
    display: inline-block;
    margin-left: 6px;
    padding: 0 5px;
    border-radius: 999px;
    background: var(--rule);
    color: var(--muted);
    font-size: 10px;
    font-weight: 600;
    line-height: 1.6;
  }

  .archive__chip--draft.is-active .archive__chip-count {
    background: var(--paper);
    color: var(--accent);
  }

  .archive__draft-note {
    margin: 0 0 18px;
    font-size: 13px;
    color: var(--muted);
    font-family: var(--font-sans);
  }

  .group.is-hidden { display: none; }

  @media (max-width: 640px) {
    .masthead__name {
      font-size: 44px;
    }
    .masthead__role {
      font-size: 19px;
    }
    .masthead {
      margin-bottom: 48px;
    }
  }
</style>

<script>
  // Each chip mirrors visibility of its matching .group[data-kind=...].
  // Drafts is just another data-kind value ("draft") that happens to
  // start in the off state.
  const archive = document.querySelector<HTMLElement>('.archive');
  if (archive) {
    const chips = archive.querySelectorAll<HTMLButtonElement>('.archive__chip');
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const kind = chip.dataset.kind;
        if (!kind) return;
        const active = !chip.classList.contains('is-active');
        chip.classList.toggle('is-active', active);
        chip.setAttribute('aria-pressed', active ? 'true' : 'false');
        archive
          .querySelectorAll<HTMLElement>(`.group[data-kind="${kind}"]`)
          .forEach((g) => g.classList.toggle('is-hidden', !active));
      });
    });
  }
</script>
