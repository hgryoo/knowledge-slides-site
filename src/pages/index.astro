---
import Base from '../layouts/Base.astro';
import FeaturedDeck from '../components/FeaturedDeck.astro';
import DeckRow from '../components/DeckRow.astro';
import { loadDecks, groupByKind, collectTopics } from '../lib/decks';

const decks = loadDecks();
// Drafts are NOT segregated into their own section anymore — they
// inline into the same Talks / Reading groups as published decks, with
// `data-draft="true"` on the row. The draft chip then acts as a
// row-level filter (default: hide drafts; toggled on: show drafts
// only). This makes "reading + draft" mean "drafts in reading", which
// matches the chip-combination user expectation.
// Hidden ('local-only') decks never claim the Featured slot — they're
// private to the local viewer, not the showcase. Drafts are likewise
// not featurable.
const featuredCandidate = decks.find((d) => !d.draft && !d.hidden);
const featured = featuredCandidate;
const rest = decks.filter((d) => d.slug !== featuredCandidate?.slug);
const drafts = decks.filter((d) => d.draft);
const kindGroups = groupByKind(rest);
const topicEntries = collectTopics(decks);
const total = decks.length;

// Cross-link to knowledge-docs-site. Only rendered when the env var is
// set so local dev (which usually doesn't have docs-site running) stays
// clean; the CI workflow sets it to the deployed prod URL.
const docsSiteUrl = process.env.DOCS_SITE_URL ?? null;
---

<Base
  title="Hyung-Gyu Ryoo's — Talks & Notes"
  description="주로 발표 자료. 곁가지로 코드 분석 노트와 읽은 책·논문 메모."
  variant="full"
>
  <header class="masthead">
    <h1 class="masthead__name">Hyung-Gyu Ryoo's</h1>
    <p class="masthead__role"><em>Talks &amp; Notes</em></p>
    <p class="masthead__lede">
      주로 발표 자료를 모아둡니다. 곁가지로 코드 분석 노트와
      읽은 책 · 논문에 대한 메모도 함께 둡니다.
      관심사는 데이터베이스 내부와 그 주변의 시스템 소프트웨어입니다.
    </p>
    {docsSiteUrl && (
      <p class="masthead__crosslink">
        함께 보기 · <a href={docsSiteUrl} target="_blank" rel="noopener">Notes &amp; Analyses ↗</a>
      </p>
    )}
  </header>

  {total === 0 ? (
    <p class="empty">
      등록된 자료가 없습니다. <code>knowledge-slides/decks/&lt;slug&gt;/metadata.json</code>을 추가하세요.
    </p>
  ) : (
    <>
      {featured && (
        <section class="block">
          <h2 class="block__heading">
            <span class="block__rule" aria-hidden="true"></span>
            <span class="block__label">Featured</span>
          </h2>
          <FeaturedDeck deck={featured} />
        </section>
      )}

      {(rest.length > 0 || drafts.length > 0) && (
        <section class="archive">
          <div class="archive__chips" role="group" aria-label="Filter by kind">
            {kindGroups.map((group) => (
              <button
                type="button"
                class="archive__chip is-active"
                data-kind={group.kind}
                aria-pressed="true"
              >{group.label}</button>
            ))}
            <span class="archive__chip-sep" aria-hidden="true"></span>
            <button
              type="button"
              class="archive__chip archive__chip--draft"
              data-kind="draft"
              aria-pressed="false"
            >Drafts<span class="archive__chip-count">{drafts.length}</span></button>
          </div>

          {topicEntries.length > 0 && (
            <div class="archive__chips archive__chips--topics" role="group" aria-label="Filter by topic">
              {topicEntries.map((t) => (
                <button
                  type="button"
                  class="archive__chip archive__chip--topic"
                  data-topic={t.topic}
                  aria-pressed="false"
                >#{t.topic}<span class="archive__chip-count">{t.count}</span></button>
              ))}
            </div>
          )}

          {/* Drafts are inlined into their respective Talks / Reading
              groups — each row carries `data-draft="true"`. The draft
              chip toggles archive-level `.is-draft-mode`, which the
              CSS uses to swap drafts in and published rows out. */}
          {kindGroups.map((group) => (
            <section class="group" data-kind={group.kind}>
              <h2 class="block__heading">
                <span class="block__rule" aria-hidden="true"></span>
                <span class="block__label">{group.label}</span>
              </h2>
              <div class="group__list">
                {group.decks.map((deck) => (
                  <DeckRow deck={deck} showYear />
                ))}
              </div>
            </section>
          ))}
        </section>
      )}
    </>
  )}
</Base>

<style>
  .masthead {
    margin-bottom: 64px;
  }

  .masthead__name {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 60px;
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 0 0 6px;
    color: var(--ink);
  }

  .masthead__role {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--muted);
    margin: 0 0 28px;
    letter-spacing: -0.01em;
  }

  .masthead__role em {
    font-style: italic;
  }

  .masthead__lede {
    font-size: 17px;
    color: var(--ink-soft);
    max-width: 56ch;
    margin: 0;
  }

  .masthead__crosslink {
    margin: 18px 0 0;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 0.01em;
  }

  .masthead__crosslink a {
    color: var(--accent);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: var(--muted-soft);
    text-underline-offset: 3px;
  }

  .masthead__crosslink a:hover {
    text-decoration-color: var(--accent);
  }

  .empty {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 32px 0;
    text-align: center;
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 15px;
  }

  .empty code {
    background: rgba(168, 51, 42, 0.08);
    color: var(--accent);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 13px;
  }

  .block {
    margin-bottom: 48px;
  }

  .block__heading {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 12px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .block__rule {
    width: 22px;
    height: 1px;
    background: var(--muted);
  }

  /* Card grid at wide screens. The default DeckRow uses a 3-column
     internal layout (month / thumb / body) and stacks rows vertically;
     here we turn `.group__list` into a responsive grid so two-or-three
     cards flow per row on big screens. DeckRow's own CSS handles the
     internal switch from row to vertical card via `min-width: 960px`
     media query — see DeckRow.astro. */
  .group__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 960px) {
    .group__list {
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px 28px;
    }
  }

  .group {
    margin-bottom: 48px;
  }

  .archive__chips {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin: 0 0 36px;
  }

  .archive__chip {
    appearance: none;
    background: transparent;
    border: 1px solid var(--rule);
    padding: 4px 12px;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--muted);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }

  .archive__chip:hover {
    color: var(--ink);
    border-color: var(--muted-soft);
  }

  .archive__chip.is-active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--paper);
  }

  .archive__chip.is-active::before {
    content: "✓ ";
    margin-right: 2px;
  }

  /* Drafts is a separate filter dimension from kind, so it sits past
   * a thin vertical rule and uses a dashed outline when inactive to
   * signal "not the same axis as the other chips". */
  .archive__chip-sep {
    display: inline-block;
    width: 1px;
    align-self: stretch;
    margin: 4px 6px;
    background: var(--rule);
  }

  .archive__chip--draft {
    border-style: dashed;
  }

  .archive__chip--draft.is-active {
    border-style: solid;
  }

  .archive__chip-count {
    display: inline-block;
    margin-left: 6px;
    padding: 0 5px;
    border-radius: 999px;
    background: var(--rule);
    color: var(--muted);
    font-size: 10px;
    font-weight: 600;
    line-height: 1.6;
  }

  .archive__chip--draft.is-active .archive__chip-count {
    background: var(--paper);
    color: var(--accent);
  }

  .archive__draft-note {
    margin: 0 0 18px;
    font-size: 13px;
    color: var(--muted);
    font-family: var(--font-sans);
  }

  /* Topic chips are a separate filter dimension, default-OFF.
   * Smaller + monospace to read as a tag rather than a category button. */
  .archive__chips--topics {
    margin-top: -22px;
    margin-bottom: 36px;
  }

  .archive__chip--topic {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 3px 10px;
    letter-spacing: 0;
    color: var(--muted);
  }

  .archive__chip--topic::before {
    content: none !important;
  }

  .archive__chip--topic.is-active {
    background: transparent;
    color: var(--accent);
    border-color: var(--accent);
  }

  .archive__chip--topic.is-active .archive__chip-count {
    background: var(--accent);
    color: var(--paper);
  }

  /* .row is declared in DeckRow.astro, which Astro scopes under a
   * different cid hash than this file. Use :global so the JS-toggled
   * class actually hides the element. */
  :global(.row.is-topic-hidden) { display: none; }
  .group.is-hidden,
  .group.is-empty { display: none; }

  /* Drafts visibility rule. Parent-scoped so the `.row` element's own
   * `display:` (grid at narrow, flex/column at wide) flows through
   * unchanged when the row IS allowed to render.
   *
   *   default                       : hide draft rows
   *   .archive.is-draft-mode (on)   : hide non-draft rows
   *
   * Drafts are inlined into the same Talks / Reading groups so the
   * kind chip and the draft chip compose by intersection — e.g.
   * "reading + draft" yields drafts in the reading group. */
  .archive:not(.is-draft-mode) :global(.row--draft) { display: none; }
  .archive.is-draft-mode :global(.row:not(.row--draft)) { display: none; }

  @media (max-width: 640px) {
    .masthead__name {
      font-size: 44px;
    }
    .masthead__role {
      font-size: 19px;
    }
    .masthead {
      margin-bottom: 48px;
    }
  }
</style>

<script>
  // Two filter dimensions in one chip surface:
  //   - data-kind chips (kind + drafts): toggle group sections via .is-hidden.
  //     Kind chips are additive among themselves; Drafts is a separate axis
  //     and toggles a *drafts-only view* — activating Drafts hides every
  //     kind group and shows only the drafts group; deactivating restores
  //     the kind groups according to their individual chip states. Clicking
  //     any kind chip while Drafts is active automatically exits Drafts mode.
  //   - data-topic chips: toggle individual rows via .is-topic-hidden, then
  //     mark the parent group .is-empty if every row in it ended up hidden.
  const archive = document.querySelector<HTMLElement>('.archive');
  if (archive) {
    const applyTopicFilter = () => {
      const selected = new Set<string>();
      archive
        .querySelectorAll<HTMLButtonElement>('.archive__chip--topic.is-active')
        .forEach((c) => {
          if (c.dataset.topic) selected.add(c.dataset.topic);
        });
      archive.querySelectorAll<HTMLElement>('.row').forEach((row) => {
        const rowTopics = (row.dataset.topics ?? '').split(' ').filter(Boolean);
        const visible =
          selected.size === 0 || rowTopics.some((t) => selected.has(t));
        row.classList.toggle('is-topic-hidden', !visible);
      });
      archive.querySelectorAll<HTMLElement>('.group').forEach((g) => {
        const total = g.querySelectorAll('.row').length;
        const visible = g.querySelectorAll('.row:not(.is-topic-hidden)').length;
        g.classList.toggle('is-empty', total > 0 && visible === 0);
      });
    };

    const draftChip = archive.querySelector<HTMLButtonElement>(
      '.archive__chip[data-kind="draft"]',
    );

    // applyVisibility composes three filter dimensions:
    //   - kind chips (talks / reading) toggle group sections via .is-hidden
    //   - draft chip toggles archive-level .is-draft-mode; the CSS swaps
    //     draft rows in and published rows out (drafts are inlined into
    //     the same Talks / Reading sections, so "reading + draft" gives
    //     drafts that are reading — the intersection the user expects)
    //   - topic chips already filter at row level via .is-topic-hidden
    //     and bubble .is-empty up to the parent group
    const applyVisibility = () => {
      const draftsMode = draftChip?.classList.contains('is-active') ?? false;
      archive.classList.toggle('is-draft-mode', draftsMode);
      archive.querySelectorAll<HTMLElement>('.group').forEach((g) => {
        const k = g.dataset.kind;
        if (!k) return;
        const c = archive.querySelector<HTMLButtonElement>(
          `.archive__chip[data-kind="${k}"]`,
        );
        const active = c?.classList.contains('is-active') ?? true;
        g.classList.toggle('is-hidden', !active);
      });
    };

    archive
      .querySelectorAll<HTMLButtonElement>('.archive__chip')
      .forEach((chip) => {
        chip.addEventListener('click', () => {
          const active = !chip.classList.contains('is-active');
          chip.classList.toggle('is-active', active);
          chip.setAttribute('aria-pressed', active ? 'true' : 'false');

          if (chip.classList.contains('archive__chip--topic')) {
            applyTopicFilter();
            return;
          }
          applyVisibility();
        });
      });
  }
</script>
