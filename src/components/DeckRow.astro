---
import type { DeckMetadata } from '../lib/decks';
import { monthLabel } from '../lib/decks';

interface Props {
  deck: DeckMetadata;
  /** When grouping by kind the year heading is gone, so the row must
   *  carry its own year next to the month. */
  showYear?: boolean;
}

const { deck, showYear = false } = Astro.props;
const month = monthLabel(deck.date);
const year = deck.date?.slice(0, 4);
const dateLabel = showYear && year ? (month ? `${month} ${year}` : year) : month;
---

<article
  class={`row${deck.available ? '' : ' row--missing'}${showYear ? ' row--with-year' : ''}${deck.draft ? ' row--draft' : ''}`}
  data-topics={deck.topics.join(' ')}
  data-draft={deck.draft ? 'true' : 'false'}
>
  <div class="row__month">{dateLabel}</div>

  <a class="row__thumb" href={deck.primaryUrl ?? '#'} aria-hidden={deck.primaryThumbnail ? undefined : 'true'}>
    {deck.primaryThumbnail ? (
      <img src={deck.primaryThumbnail} alt="" loading="lazy" />
    ) : (
      <span class="row__thumb-fallback">{deck.title.slice(0, 1)}</span>
    )}
  </a>

  <div class="row__body">
    <h3 class="row__title">
      {deck.primaryUrl ? (
        <a href={deck.primaryUrl}>{deck.title}</a>
      ) : (
        <span>{deck.title}</span>
      )}
      {!deck.available && <span class="row__pending">(unbuilt)</span>}
      {deck.draft && <span class="row__draft-chip">draft</span>}
      {deck.hidden && <span class="row__local-chip" title="hidden from the public landing — only listed locally">local</span>}
    </h3>

    {deck.subtitle && <p class="row__subtitle">{deck.subtitle}</p>}
    {deck.summary && <p class="row__summary">{deck.summary}</p>}

    <div class="row__meta">
      {deck.tags && deck.tags.length > 0 && (
        <span class="row__tags">
          {deck.tags.map((tag, i) => (
            <>
              {i > 0 && ', '}
              <span>{tag}</span>
            </>
          ))}
        </span>
      )}
      <span class="row__langs">
        {deck.languages.map((l, i) => (
          <>
            {i > 0 && <span class="row__sep">·</span>}
            <span class="row__lang">
              <span class="row__lang-label">{l.label}</span>
              {l.html ? <a href={l.html}>html</a> : <span class="row__muted">html</span>}
              {l.pdf && (
                <>
                  <span class="row__dot">·</span>
                  <a href={l.pdf} target="_blank" rel="noopener">pdf</a>
                </>
              )}
            </span>
          </>
        ))}
      </span>
    </div>

    {deck.documents.length > 0 && (
      <div class="row__docs">
        {deck.documents.map((doc, i) => (
          <span class="row__doc">
            {i > 0 && <span class="row__sep">·</span>}
            <span class="row__doc-kind">{doc.kind ?? 'docs'}</span>
            <a href={doc.url} target={doc.url.startsWith('http') ? '_blank' : undefined} rel={doc.url.startsWith('http') ? 'noopener' : undefined}>
              {doc.label}
            </a>
            <span class="row__doc-format">· {doc.format ?? 'link'}</span>
          </span>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .row {
    display: grid;
    grid-template-columns: 44px 96px 1fr;
    column-gap: 20px;
    padding: 28px 0;
    border-bottom: 1px solid var(--rule);
  }

  .row--with-year {
    grid-template-columns: 78px 96px 1fr;
  }

  .row:last-child {
    border-bottom: none;
  }

  .row--missing {
    opacity: 0.55;
  }

  .row__month {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-top: 8px;
  }

  .row__thumb {
    display: block;
    position: relative;
    aspect-ratio: 16 / 9;
    background: #efece4;
    border: 1px solid var(--rule);
    border-radius: 3px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .row__thumb:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 14px -8px rgba(20, 18, 14, 0.3);
  }

  .row__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .row__thumb-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 28px;
    color: var(--muted-soft);
  }

  .row__body {
    min-width: 0;
  }

  .row__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 24px;
    line-height: 1.2;
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }

  .row__title a {
    color: var(--ink);
    text-decoration: none;
  }

  .row__title a:hover {
    color: var(--accent);
  }

  .row__pending {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--muted);
    margin-left: 8px;
    vertical-align: middle;
  }

  .row__draft-chip {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--ink);
    background: rgba(168, 51, 42, 0.10);
    padding: 1px 6px;
    border-radius: 3px;
    margin-left: 8px;
    vertical-align: middle;
  }

  .row__local-chip {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--muted);
    background: rgba(20, 18, 14, 0.06);
    border: 1px dashed var(--muted-soft);
    padding: 0 5px;
    border-radius: 3px;
    margin-left: 8px;
    vertical-align: middle;
  }

  /* Draft visibility is controlled globally from index.astro's style
     block via `.archive.is-draft-mode` — drafts are hidden by default
     and swap in for published rows when the user toggles the Drafts
     chip. See index.astro for the actual display rules. */

  .row__subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
    color: var(--muted);
    margin: 0 0 10px;
  }

  .row__summary {
    color: var(--ink-soft);
    margin: 10px 0 14px;
    font-size: 15px;
  }

  .row__meta {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--muted);
    font-family: var(--font-sans);
  }

  .row__tags span {
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .row__langs {
    margin-left: auto;
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }

  .row__lang {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }

  .row__lang-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--ink);
    background: rgba(168, 51, 42, 0.08);
    padding: 1px 6px;
    border-radius: 3px;
  }

  .row__lang a {
    color: var(--muted);
    text-decoration: underline;
    text-decoration-color: var(--muted-soft);
    text-underline-offset: 2px;
  }

  .row__lang a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .row__muted {
    color: var(--muted-soft);
    text-decoration: line-through;
    text-decoration-color: var(--muted-soft);
  }

  .row__sep {
    color: var(--muted-soft);
    margin: 0 2px;
  }

  .row__dot {
    color: var(--muted-soft);
  }

  .row__docs {
    margin-top: 10px;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--muted);
  }

  .row__doc {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }

  .row__doc-kind {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--ink);
    background: rgba(46, 84, 158, 0.08);
    padding: 1px 6px;
    border-radius: 3px;
  }

  .row__doc-format {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted-soft);
    letter-spacing: 0.02em;
  }

  .row__doc a {
    color: var(--muted);
    text-decoration: underline;
    text-decoration-color: var(--muted-soft);
    text-underline-offset: 2px;
  }

  .row__doc a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  @media (max-width: 640px) {
    .row {
      grid-template-columns: 36px 72px 1fr;
      column-gap: 14px;
      padding: 22px 0;
    }
    .row--with-year {
      grid-template-columns: 64px 72px 1fr;
    }
    .row__title {
      font-size: 21px;
    }
  }

  /* Wide screens: switch from horizontal list row to vertical card.
     The parent `.group__list` becomes a multi-column grid in
     index.astro; here we just restructure each row so the thumb sits
     on top and the body flows beneath, like a poster card. */
  @media (min-width: 960px) {
    .row, .row--with-year {
      display: flex;
      flex-direction: column;
      grid-template-columns: none;
      column-gap: 0;
      padding: 0;
      border-bottom: none;
    }
    .row__month {
      padding-top: 0;
      margin: 0 0 8px;
      font-size: 11px;
    }
    .row__thumb {
      margin: 0 0 14px;
    }
    .row__title {
      font-size: 20px;
      line-height: 1.25;
    }
    .row__subtitle {
      font-size: 14px;
    }
    .row__summary {
      font-size: 14px;
      /* multi-line clamp keeps the cards same height-ish */
      display: -webkit-box;
      -webkit-line-clamp: 4;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .row__meta {
      gap: 10px;
    }
    .row__langs {
      margin-left: 0;
    }
  }
</style>
