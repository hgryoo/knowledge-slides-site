---
import type { DeckMetadata } from '../lib/decks';
import { monthLabel } from '../lib/decks';

interface Props {
  deck: DeckMetadata;
  /** When grouping by kind the year heading is gone, so the row must
   *  carry its own year next to the month. */
  showYear?: boolean;
}

const { deck, showYear = false } = Astro.props;
const month = monthLabel(deck.date);
const year = deck.date?.slice(0, 4);
const dateLabel = showYear && year ? (month ? `${month} ${year}` : year) : month;
---

<article
  class={`row${deck.available ? '' : ' row--missing'}${showYear ? ' row--with-year' : ''}`}
  data-topics={deck.topics.join(' ')}
>
  <div class="row__month">{dateLabel}</div>

  <a class="row__thumb" href={deck.primaryUrl ?? '#'} aria-hidden={deck.primaryThumbnail ? undefined : 'true'}>
    {deck.primaryThumbnail ? (
      <img src={deck.primaryThumbnail} alt="" loading="lazy" />
    ) : (
      <span class="row__thumb-fallback">{deck.title.slice(0, 1)}</span>
    )}
  </a>

  <div class="row__body">
    <h3 class="row__title">
      {deck.primaryUrl ? (
        <a href={deck.primaryUrl}>{deck.title}</a>
      ) : (
        <span>{deck.title}</span>
      )}
      {!deck.available && <span class="row__pending">(unbuilt)</span>}
    </h3>

    {deck.subtitle && <p class="row__subtitle">{deck.subtitle}</p>}
    {deck.summary && <p class="row__summary">{deck.summary}</p>}

    <div class="row__meta">
      {deck.tags && deck.tags.length > 0 && (
        <span class="row__tags">
          {deck.tags.map((tag, i) => (
            <>
              {i > 0 && ', '}
              <span>{tag}</span>
            </>
          ))}
        </span>
      )}
      <span class="row__langs">
        {deck.languages.map((l, i) => (
          <>
            {i > 0 && <span class="row__sep">·</span>}
            <span class="row__lang">
              <span class="row__lang-label">{l.label}</span>
              {l.html ? <a href={l.html}>html</a> : <span class="row__muted">html</span>}
              {l.pdf && (
                <>
                  <span class="row__dot">·</span>
                  <a href={l.pdf} target="_blank" rel="noopener">pdf</a>
                </>
              )}
            </span>
          </>
        ))}
      </span>
    </div>
  </div>
</article>

<style>
  .row {
    display: grid;
    grid-template-columns: 44px 96px 1fr;
    column-gap: 20px;
    padding: 28px 0;
    border-bottom: 1px solid var(--rule);
  }

  .row--with-year {
    grid-template-columns: 78px 96px 1fr;
  }

  .row:last-child {
    border-bottom: none;
  }

  .row--missing {
    opacity: 0.55;
  }

  .row__month {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-top: 8px;
  }

  .row__thumb {
    display: block;
    position: relative;
    aspect-ratio: 16 / 9;
    background: #efece4;
    border: 1px solid var(--rule);
    border-radius: 3px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .row__thumb:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 14px -8px rgba(20, 18, 14, 0.3);
  }

  .row__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .row__thumb-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 28px;
    color: var(--muted-soft);
  }

  .row__body {
    min-width: 0;
  }

  .row__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 24px;
    line-height: 1.2;
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }

  .row__title a {
    color: var(--ink);
    text-decoration: none;
  }

  .row__title a:hover {
    color: var(--accent);
  }

  .row__pending {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--muted);
    margin-left: 8px;
    vertical-align: middle;
  }

  .row__subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
    color: var(--muted);
    margin: 0 0 10px;
  }

  .row__summary {
    color: var(--ink-soft);
    margin: 10px 0 14px;
    font-size: 15px;
  }

  .row__meta {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--muted);
    font-family: var(--font-sans);
  }

  .row__tags span {
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .row__langs {
    margin-left: auto;
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }

  .row__lang {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }

  .row__lang-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--ink);
    background: rgba(168, 51, 42, 0.08);
    padding: 1px 6px;
    border-radius: 3px;
  }

  .row__lang a {
    color: var(--muted);
    text-decoration: underline;
    text-decoration-color: var(--muted-soft);
    text-underline-offset: 2px;
  }

  .row__lang a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .row__muted {
    color: var(--muted-soft);
    text-decoration: line-through;
    text-decoration-color: var(--muted-soft);
  }

  .row__sep {
    color: var(--muted-soft);
    margin: 0 2px;
  }

  .row__dot {
    color: var(--muted-soft);
  }

  @media (max-width: 640px) {
    .row {
      grid-template-columns: 36px 72px 1fr;
      column-gap: 14px;
      padding: 22px 0;
    }
    .row--with-year {
      grid-template-columns: 64px 72px 1fr;
    }
    .row__title {
      font-size: 21px;
    }
  }
</style>
